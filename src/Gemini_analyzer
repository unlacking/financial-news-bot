import os
import json
from pathlib import Path
from typing import List, Dict, Any
from pydantic import BaseModel, Field
from google import genai
from google.genai import types
from dotenv import load_dotenv

# Định vị thư mục gốc để nạp file .env khi chạy test độc lập
current_dir = Path(__file__).resolve().parent
project_root = current_dir.parent

# 1. Định nghĩa Schema đầu ra bằng Pydantic để bắt buộc Gemini trả về cấu trúc JSON này
class NewsAnalysisSchema(BaseModel):
    tom_tat: str = Field(description="Tóm tắt ngắn gọn nội dung chính của tin tức từ 1 đến 2 câu bằng tiếng Việt.")
    cam_xuc: str = Field(description="Phân loại cảm xúc của tin tức đối với thị trường. Bắt buộc phải là một trong ba giá trị: 'tích cực', 'tiêu cực', hoặc 'trung tính'.")
    ma_lien_quan: List[str] = Field(description="Danh sách các mã cổ phiếu (ticker) xuất hiện hoặc bị ảnh hưởng bởi tin tức này (ví dụ: ['FPT', 'VNM']). Nếu không có mã nào cụ thể, trả về mảng rỗng [].")
    do_quan_trong: str = Field(description="Mức độ quan trọng của tin tức đối với quyết định đầu tư. Bắt buộc phải là một trong ba giá trị: 'Cao', 'Trung bình', 'Thấp'.")

def analyze(news_item: dict) -> dict:
    """
    Phân tích cảm xúc và trích xuất thông tin có cấu trúc từ một bản tin tài chính.
    
    Args:
        news_item (dict): Dictionary chứa thông tin bài viết (yêu cầu tối thiểu có 'title' và 'summary').
        
    Returns:
        dict: Kết quả phân tích có cấu trúc JSON dạng cặp Key-Value.
    """
    # Khởi tạo Client bằng SDK mới (tự động lấy GEMINI_API_KEY từ môi trường)
    try:
        client = genai.Client()
    except Exception as e:
        print(f"[ERROR] Không thể khởi tạo Gemini Client. Kiểm tra biến môi trường. Chi tiết: {e}")
        return {}

    title = news_item.get("title", "")
    summary = news_item.get("summary", "")

    # Định hình vai trò chuyên gia của hệ thống
    system_instruction = (
        "You are an expert financial data analyst specializing in sentiment analysis and entity extraction. "
        "Your task is to analyze the provided financial news item and populate the requested schema fields accurately. "
        "Strictly adhere to the specified JSON schema constraints. Do not include conversational text or markdown code blocks."
    )

    user_prompt = f"Hãy phân tích bản tin tài chính sau đây:\nTiêu đề: {title}\nTóm tắt: {summary}"

    try:
        # Gọi model mới nhất với cấu hình Structured Output
        response = client.models.generate_content(
            model='gemini-2.5-flash',
            contents=user_prompt,
            config=types.GenerateContentConfig(
                system_instruction=system_instruction,
                temperature=0.1,  # Đặt thấp để đảm bảo tính nhất quán của định dạng dữ liệu
                response_mime_type="application/json",
                response_schema=NewsAnalysisSchema,
            ),
        )

        raw_text = response.text.strip()
        
        # Tiến hành parse JSON an toàn và kiểm tra tính toàn vẹn dữ liệu
        try:
            analysis_result = json.loads(raw_text)
            
            # Đảm bảo phòng ngừa từ xa nếu thiếu trường (Fallbacks)
            required_fields = ["tom_tat", "cam_xuc", "ma_lien_quan", "do_quan_trong"]
            for field in required_fields:
                if field not in analysis_result:
                    if field == "ma_lien_quan":
                        analysis_result[field] = []
                    else:
                        analysis_result[field] = "Không xác định"
                        
            return analysis_result

        except json.JSONDecodeError as json_err:
            print(f"[ERROR] Lỗi phân tách (parse) chuỗi JSON từ Gemini: {json_err}")
            print(f"Chuỗi thô gây lỗi: {raw_text}")
            return {}

    except Exception as api_err:
        print(f"[ERROR] Lỗi kết nối hoặc xử lý từ API Gemini: {api_err}")
        return {}


# --- Khu vực chạy thử nghiệm (Local Test Engine) ---
if __name__ == "__main__":
    load_dotenv(dotenv_path=project_root / ".env")
    
    # Dữ liệu tin tức giả lập mẫu
    sample_news = {
        "source": "CafeF",
        "title": "Hòa Phát (HPG) báo lãi ròng quý tăng vọt nhờ sản lượng thép xuất khẩu sang châu Âu phục hồi",
        "summary": "Tập đoàn Hòa Phát vừa công bố báo cáo tài chính với doanh thu thuần đạt mức tăng trưởng ấn tượng, biên lợi nhuận gộp cải thiện đáng kể do giá nguyên liệu đầu vào giảm."
    }
    
    print("--- Chạy thử nghiệm hàm analyze() với Structured Output ---")
    output = analyze(sample_news)
    
    print("\nKết quả trả về dưới dạng Python Dictionary:")
    print(json.dumps(output, ensure_ascii=False, indent=4))