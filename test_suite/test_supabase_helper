# test_suite/test_supabase_helper.py
import os
import sys
import json
from datetime import datetime

project_root = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))
if project_root not in sys.path:
    sys.path.insert(0, project_root)

from src.supabase_helper import insert_json_to_table, STOCKS_TABLE

def run_supabase_helper_test():
    print("====================================")
    print("STARTING SUPABASE HELPER ISOLATION TEST")
    print("====================================\n")

    # Set up directory references mapping
    date_str = datetime.now().strftime("%Y-%m-%d")
    dummy_dir = os.path.join(project_root, "stock_data", date_str)
    os.makedirs(dummy_dir, exist_ok=True)
    
    dummy_file_path = os.path.join(dummy_dir, "stock_prices.json")

    # 1. Create a standardized test payload matching expectations
    mock_payload = [
        {
            "ticker": "FPT",
            "price": 135000.0,
            "percentage_change": 2.50,
            "collected_date": date_str
        }
    ]

    try:
        print(f"Writing temporary validation object file to: {dummy_file_path}")
        with open(dummy_file_path, "w", encoding="utf-8") as f:
            json.dump(mock_payload, f, indent=4)

        print(f"Invoking Supabase sync engine pipeline onto table: {STOCKS_TABLE}")
        # Execute synchronization step
        success = insert_json_to_table(local_file_path=dummy_file_path, table_name=STOCKS_TABLE)
        
        if success:
            print("\nSTATUS: SUCCESS - Payloads successfully processed and acknowledged by backend endpoints.")
        else:
            print("\nSTATUS: FAILED - Database connection rejected the insertion sequence.")
            
    except Exception as e:
        print(f"\nSTATUS: FAILED - Execution aborted due to internal helper fault: {e}")
        
    finally:
        # Clean up temporary file trace from workspace if generated
        if os.path.exists(dummy_file_path):
            os.remove(dummy_file_path)
            print("\nCleanup: Temporary validation artifacts removed.")

    print("\n====================================")
    print("SUPABASE HELPER ISOLATION TEST COMPLETE")
    print("====================================")

if __name__ == "__main__":
    run_supabase_helper_test()